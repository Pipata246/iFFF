{
  "name": "avito-playwright-parser",
  "version": "1.0.0",
  "description": "Парсер Avito на Playwright с сохранением в Excel",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "start:vps": "NODE_OPTIONS=--max-old-space-size=384 node main.js",
    "bot": "node telegram_bot.js",
    "wb:save-session": "node save_wb_storage_state.js",
    "wb:save-session-cdp": "node save_wb_storage_cdp.js",
    "postinstall": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.49.0",
    "xlsx": "^0.18.5"
  }
}
