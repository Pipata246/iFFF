[Unit]
Description=iFind parser service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/ifind
EnvironmentFile=/opt/ifind/.env
Environment=PLAYWRIGHT_HEADLESS=1
ExecStart=/usr/bin/npm run start:vps
Restart=always
RestartSec=8
User=root
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
